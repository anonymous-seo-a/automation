# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
ALLOWED_LINE_USER_ID=your_line_user_id

# Claude API
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6-20260312
CLAUDE_MODEL_OPUS=claude-opus-4-6-20260312
CLAUDE_DAILY_BUDGET_USD=1.50
CLAUDE_MONTHLY_BUDGET_USD=30.00

# Server
PORT=3000
NODE_ENV=production
DB_PATH=./data/mothership.db
LOG_DIR=./logs
SANDBOX_DIR=/tmp/mothership/sandbox

# Admin
ADMIN_PASSWORD=your_admin_password
ADMIN_BASE_URL=https://your-domain.com
